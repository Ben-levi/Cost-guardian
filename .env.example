# --- Required ---
TABLE_NAME=state-table
COST_HISTORY_TABLE=history-table
ALERTS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:topic

# --- Cost settings ---
THRESHOLD=0.10
COST_EXPLORER_GRANULARITY=DAILY
COST_EXPLORER_METRIC=UnblendedCost
HISTORY_TTL_DAYS=30
ENABLE_DAILY_PK=false

# --- Monthly rollup ---
ENABLE_MONTHLY_ROLLUP=true
MONTHLY_ROLLUP_TTL_DAYS=400

# --- SNS pending retry ---
PENDING_ALERT_KEY=alert_pending
PENDING_ALERT_TTL_DAYS=7

# --- Enforcement (EC2 stop) ---
ENFORCEMENT_ENABLED=false
ENFORCEMENT_DRY_RUN=true
ENFORCEMENT_TAG_KEY=CostControl
ENFORCEMENT_TAG_VALUE=StopOnBreach
ENFORCEMENT_REGIONS=us-east-1

# Optional region fallbacks used by AWS SDK
AWS_REGION=us-east-1
